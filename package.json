{
  "name": "vnls",
  "version": "0.1.0",
  "private": true,
  "description": "ПМК во имя святых мучениц Веры, Надежды, Любови и матери их Софии - православный молодёжный клуб Узбекистана (vnls.uz)",
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=20"
  },
  "prettier": {
    "semi": true,
    "singleQuote": false,
    "trailingComma": "all",
    "printWidth": 100,
    "tabWidth": 2,
    "plugins": ["prettier-plugin-tailwindcss"]
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,md,css}\"",
    "db:generate": "turbo run db:generate",
    "db:migrate": "pnpm --filter @vnls/db run db:migrate",
    "db:migrate:dev": "pnpm --filter @vnls/db run db:migrate:dev",
    "db:push": "pnpm --filter @vnls/db run db:push",
    "db:seed": "pnpm --filter @vnls/db run db:seed",
    "db:studio": "pnpm --filter @vnls/db run db:studio",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}
